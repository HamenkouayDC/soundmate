DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

POSTGRES_DB=soundmate
POSTGRES_USER=soundmate
POSTGRES_PASSWORD=soundmate
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Last.fm — для пересборки music_embedding из реального аккаунта
LASTFM_API_KEY=

# Spotify — ключи от тимлида (Developer Dashboard)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# SoundCloud — ключи от тимлида (Artist Pro app)
SOUNDCLOUD_CLIENT_ID=
SOUNDCLOUD_CLIENT_SECRET=
