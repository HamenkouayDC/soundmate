# Скопируй этот файл в .env и заполни своими значениями.
# Никогда не коммитьте .env в Git — он уже должен быть в .gitignore.

# --- Spotify ---
# Берём из https://developer.spotify.com/dashboard -> твоё приложение -> Settings
SPOTIFY_CLIENT_ID=вставь_сюда_client_id
SPOTIFY_CLIENT_SECRET=вставь_сюда_client_secret
# Должен ТОЧНО совпадать с Redirect URI, указанным в настройках приложения на сайте Spotify
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# --- Last.fm ---
# Берём из https://www.last.fm/api/account/create
LASTFM_API_KEY=	вставить
# Имя любого тестового пользователя Last.fm с историей прослушиваний
# (можно своё, если есть аккаунт, или любое публичное активное имя для теста структуры ответа)
LASTFM_TEST_USERNAME=вставить
